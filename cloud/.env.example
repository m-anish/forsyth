# Copy to .env and fill in. Never commit .env.

# Postgres password (compose-internal user 'forsyth')
DB_PASSWORD=change-me

# Admin bearer key: creates stations, triggers jobs. Long and random.
ADMIN_KEY=change-me-long-random

# Public URL the dashboard/api is served at (used in links + WU uploads)
PUBLIC_BASE_URL=http://localhost:8080

# MQTT credentials the api's bridge logs in with (create via mosquitto_passwd)
MQTT_APP_USER=forsyth-api
MQTT_APP_PASSWORD=

# Weather Underground uploads (per-station IDs/keys live in the stations table;
# this is the global on/off — leave false until real stations exist)
WU_ENABLED=false

# Optional: OpenAI key for LLM-written weather-event summaries on the dashboard.
# Leave empty for the (free, offline) rule-based summaries.
OPENAI_API_KEY=

# Feature switches (all default on)
FORECAST_ENABLED=true
REPORTS_ENABLED=true
SIGNUP_ENABLED=true

# Optional OAuth sign-in. Register each app with redirect URI:
#   {PUBLIC_BASE_URL}/api/v1/auth/oauth/google/callback
#   {PUBLIC_BASE_URL}/api/v1/auth/oauth/github/callback
# Buttons appear in the sign-in dialog only when id+secret are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# prod profile only: domain Caddy answers for
DOMAIN=live.forsyth.starstucklab.com

# sim profile knobs
SIM_BACKFILL_DAYS=7
SIM_INTERVAL_S=60
SKYCAM_INTERVAL_S=180
SKYCAM_BACKFILL=1
